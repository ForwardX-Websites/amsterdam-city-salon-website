<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo" aria-label="{{ site.name }} home">
      <img src="/assets/images/logo/logo-groen.png" alt="{{ site.name }} logo" width="120" height="95">
    </a>

    <nav class="site-nav" id="siteNav" aria-label="Hoofdnavigatie">
      <ul>
        <li><a href="/" {% if page.url == "/" %}class="is-active" aria-current="page"{% endif %}>Home</a></li>
        <li><a href="/behandelingen/" {% if "/behandelingen/" in page.url %}class="is-active" aria-current="page"{% endif %}>Behandelingen & prijzen</a></li>
        <li><a href="/team/" {% if page.url == "/team/" %}class="is-active" aria-current="page"{% endif %}>Team</a></li>
        <li><a href="/producten/" {% if page.url == "/producten/" %}class="is-active" aria-current="page"{% endif %}>Producten</a></li>
        <li><a href="/contact/" {% if page.url == "/contact/" %}class="is-active" aria-current="page"{% endif %}>Contact</a></li>
      </ul>
    </nav>

    <div class="header-cta">
      <a href="tel:{{ site.contact.phoneLink }}" class="hdr-bellen__btn" aria-label="Bel {{ site.name }}: {{ site.contact.phone }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
      </a>
      <a href="{{ site.booking.link }}" class="btn btn--primary btn--sm hdr-booking__btn">Afspraak<span class="hdr-booking__long"> maken</span></a>
    </div>

    <button class="hamburger" id="hamburger" type="button" aria-label="Menu openen" aria-expanded="false" aria-controls="siteNav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
